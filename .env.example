# Variáveis de ambiente - FinTech Flow Backend
# Copie este arquivo para .env e configure seus valores

# Porta do servidor
PORT=3333

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# Chave secreta para JWT (gerar uma chave forte)
JWT_SECRET=sua_chave_secreta_aqui

# Configurações de banco de dados (se usar)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fintech_flow
DB_USER=seu_usuario
DB_PASS=sua_senha

# Outras configurações
NODE_ENV=development
